{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Smoke stack: one bucket + one EC2 with cfn-init metadata + a parameter-group block.",
  "Metadata": {
    "AWS::CloudFormation::Interface": {
      "ParameterGroups": [
        {
          "Label": {
            "default": "Compute"
          },
          "Parameters": [
            "InstanceType"
          ]
        }
      ]
    }
  },
  "Resources": {
    "SmokeBucket": {
      "Properties": {
        "BucketName": "smoke-bucket"
      },
      "Type": "AWS::S3::Bucket"
    },
    "WebServer": {
      "Metadata": {
        "AWS::CloudFormation::Init": {
          "configSets": {
            "default": [
              "install"
            ]
          },
          "install": {
            "packages": {
              "yum": {
                "httpd": []
              }
            }
          }
        }
      },
      "Properties": {
        "ImageId": "ami-0abcdef1234567890",
        "InstanceType": "t3.micro"
      },
      "Type": "AWS::EC2::Instance"
    }
  }
}
