common --enable_bzlmod

common --registry=https://raw.githubusercontent.com/fastverk/bazel-registry/main/
common --registry=https://bcr.bazel.build/

# Lombok (used by the upstream CFN assembler at build time) hasn't
# released a JDK 25-compatible build yet, so pin the toolchain at
# JDK 21. The non-Lombok bits compile cleanly against newer JDKs;
# if/when Lombok ships a JDK 25 release, this pin can come off.
build --java_runtime_version=remotejdk_21
build --tool_java_runtime_version=remotejdk_21
build --java_language_version=21
build --tool_java_language_version=21

test --test_output=errors
test --test_summary=terse
