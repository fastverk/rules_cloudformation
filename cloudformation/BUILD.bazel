# ---- diff_test gates -------------------------------------------------------

diff_test(name = "storage_up_to_date", file1 = "storage.bzl", file2 = ":storage_gen")
diff_test(name = "compute_up_to_date", file1 = "compute.bzl", file2 = ":compute_gen")
diff_test(name = "identity_up_to_date", file1 = "identity.bzl", file2 = ":identity_gen")
diff_test(name = "messaging_up_to_date", file1 = "messaging.bzl", file2 = ":messaging_gen")
diff_test(name = "observability_up_to_date", file1 = "observability.bzl", file2 = ":observability_gen")
diff_test(name = "database_up_to_date", file1 = "database.bzl", file2 = ":database_gen")

# `bazel run //cloudformation:update` regenerates every group's .bzl.
write_source_files(
    name = "update",
    files = {
        "storage.bzl": ":storage_gen",
        "compute.bzl": ":compute_gen",
        "identity.bzl": ":identity_gen",
        "messaging.bzl": ":messaging_gen",
        "observability.bzl": ":observability_gen",
        "database.bzl": ":database_gen",
    },
)
