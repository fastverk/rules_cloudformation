load("@bazel_skylib//:bzl_library.bzl", "bzl_library")
load("@bazel_skylib//rules:diff_test.bzl", "diff_test")
load("@rules_jsonschema//starlark:defs.bzl", "jsonschema_starlark_codegen")
load("@rules_jsonschema//util:write_source_files.bzl", "write_source_files")
load("//cloudformation/private:assemble.bzl", "cfn_assemble")
load("//cloudformation/private:overlay.bzl", "cfn_overlay_descriptions")

package(default_visibility = ["//visibility:public"])

exports_files([
    "defs.bzl",
    "storage.bzl",
    "compute.bzl",
    "identity.bzl",
    "messaging.bzl",
    "observability.bzl",
    "database.bzl",
])

bzl_library(
    name = "defs_bzl",
    srcs = ["defs.bzl"],
    deps = [
        ":storage_lib",
        ":compute_lib",
        ":identity_lib",
        ":messaging_lib",
        ":observability_lib",
        ":database_lib",
    ],
)

# Per-group bzl_library entries — each .bzl carries typed rules for
# every top-level AWS::* resource in its group. Sub-property shapes
# (e.g. AWS::S3::Bucket_VersioningConfiguration) are present in the
# assembled schema but consumed via JSON pointers, not exposed as
# Bazel rules.
bzl_library(
    name = "storage_lib",
    srcs = ["storage.bzl"],
    deps = ["@rules_jsonschema//runtime:helpers"],
)

bzl_library(
    name = "compute_lib",
    srcs = ["compute.bzl"],
    deps = ["@rules_jsonschema//runtime:helpers"],
)

bzl_library(
    name = "identity_lib",
    srcs = ["identity.bzl"],
    deps = ["@rules_jsonschema//runtime:helpers"],
)

bzl_library(
    name = "messaging_lib",
    srcs = ["messaging.bzl"],
    deps = ["@rules_jsonschema//runtime:helpers"],
)

bzl_library(
    name = "observability_lib",
    srcs = ["observability.bzl"],
    deps = ["@rules_jsonschema//runtime:helpers"],
)

bzl_library(
    name = "database_lib",
    srcs = ["database.bzl"],
    deps = ["@rules_jsonschema//runtime:helpers"],
)

# ---- Group assembly + codegen ----------------------------------------------
# Each cfn_assemble + jsonschema_starlark_codegen pair derives one
# .bzl per AWS service group, pinned against the same upstream CFN
# Resource Specification. Adding a resource type to an existing
# group: extend the group's `includes` regex AND its kinds list.
# Adding a new group: copy the pattern below.

cfn_assemble(
    name = "assembled_storage",
    spec = "@cfn_resource_spec//file:CloudFormationResourceSpecification.json",
    group_name = "storage",
    includes = ["AWS::S3.*"],
)

# Layer the AWS-endpoint schema's rich descriptions on top of the
# assembler's URL-only ones for resources we've pinned endpoint
# coverage for (today: AWS::S3::Bucket). Endpoints for resources
# not yet pinned are no-ops — the assembler's docs come through
# unmodified. v0.3+ expands endpoint coverage to the full set.
cfn_overlay_descriptions(
    name = "assembled_storage_overlaid",
    assembled = ":assembled_storage",
    endpoints = [
        "@cfn_endpoint_aws_s3_bucket//file:aws-s3-bucket.json",
    ],
)

jsonschema_starlark_codegen(
    name = "storage_gen",
    schema = ":assembled_storage_overlaid",
    kinds = [
        ("bucket", "#/definitions/AWS_S3_Bucket/properties/Properties",
         "cloudformation_aws_s3_bucket", "CloudformationAwsS3BucketInfo"),
        ("bucket_policy", "#/definitions/AWS_S3_BucketPolicy/properties/Properties",
         "cloudformation_aws_s3_bucket_policy", "CloudformationAwsS3BucketPolicyInfo"),
        ("access_point", "#/definitions/AWS_S3_AccessPoint/properties/Properties",
         "cloudformation_aws_s3_access_point", "CloudformationAwsS3AccessPointInfo"),
    ],
)

cfn_assemble(
